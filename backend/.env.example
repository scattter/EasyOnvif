# 服务器配置
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# JWT 密钥（必须修改！）
JWT_SECRET=your-secret-key-change-this-in-production

# 数据库路径
DB_PATH=./storage/config/database.sqlite

# 存储配置
STORAGE_QUOTA_GB=50
PREBUFFER_SECONDS=10
POSTBUFFER_SECONDS=60

# MediaMTX 流媒体服务器地址
MEDIAMTX_URL=http://localhost:8889

# 摄像头配置（首次运行可不配置，通过界面设置）
# CAMERA_IP=192.168.1.100
# CAMERA_PORT=80
# CAMERA_USERNAME=admin
# CAMERA_PASSWORD=your_camera_password
# CAMERA_RTSP_URL=rtsp://admin:password@192.168.1.100:554/stream1
