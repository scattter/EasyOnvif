# EasyONVIF 环境变量配置
# 复制此文件为 .env 并修改配置

# ================================================
# 镜像仓库配置 (仅 docker-compose.release.yml 使用)
# ================================================

# 镜像仓库地址，默认 GitHub Container Registry
IMAGE_REGISTRY=ghcr.io

# 镜像命名空间（通常是 GitHub 用户名或组织名）
# 例如：IMAGE_NAMESPACE=your-github-username
IMAGE_NAMESPACE=your-github-username

# 镜像标签，默认 latest，可改为 sha-xxxxxx 固定版本
IMAGE_TAG=latest

# ================================================
# 摄像头配置 (必填)
# ================================================

# 摄像头 IP 地址
CAMERA_IP=192.168.1.100

# ONVIF 端口 (默认 80)
CAMERA_PORT=80

# ONVIF 用户名
CAMERA_USERNAME=admin

# ONVIF 密码
CAMERA_PASSWORD=your_camera_password

# RTSP 流地址 (从摄像头获取)
# 常见格式:
#   海康: rtsp://admin:password@ip:554/Streaming/Channels/101
#   大华: rtsp://admin:password@ip:554/cam/realmonitor?channel=1&subtype=0
#   通用: rtsp://admin:password@ip:554/stream1
CAMERA_RTSP_URL=rtsp://admin:your_camera_password@192.168.1.100:554/stream1

# ================================================
# 安全设置 (必填)
# ================================================

# JWT 密钥 (必须修改! 使用随机字符串)
# 生成方式: openssl rand -base64 32
JWT_SECRET=change_this_to_random_string_32_chars

# ================================================
# 存储配置 (可选)
# ================================================

# 存储配额 (GB)，默认 50
STORAGE_QUOTA_GB=50

# 预录时长 (秒)，默认 10
PREBUFFER_SECONDS=10

# 后录时长 (秒)，默认 60
POSTBUFFER_SECONDS=60

# 自动清理阈值 (%)，默认 90
CLEANUP_THRESHOLD=90

# ================================================
# 系统配置 (可选)
# ================================================

# 时区，默认 Asia/Shanghai
TZ=Asia/Shanghai

# 语言，默认 zh-CN
LANGUAGE=zh-CN

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# ================================================
# 高级配置 (可选)
# ================================================

# 后端端口，默认 3000
BACKEND_PORT=3000

# 前端端口，默认 80
FRONTEND_PORT=80

# MediaMTX WebRTC 端口，默认 8889
WEBRTC_PORT=8889

# MediaMTX RTSP 端口，默认 8554
RTSP_PORT=8554
